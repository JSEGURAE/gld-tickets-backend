// Prisma Schema - DEV Tickets
// Compatible con SQLite (local) y Azure SQL Database (producción)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique  // USER | TECHNICIAN | SUPERVISOR | ADMIN
  label       String            // Usuario | Técnico | Supervisor | Administrador
  description String?
  createdAt   DateTime @default(now())
  users       User[]

  @@map("cfg_roles")
}

model Sede {
  id        Int      @id @default(autoincrement())
  nombre    String               // "Cartago Dr. Max"
  serie     String               // "CART" — prefijo para reportes
  email     String   @unique     // correo de la sede (cruce con usuario)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  users     User[]

  @@map("Tbl_sedes")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  sedeId    Int?
  sede      Sede?    @relation(fields: [sedeId], references: [id])
  active           Boolean   @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  requestedTickets   Ticket[]           @relation("Requestor")
  assignedTickets    Ticket[]           @relation("Assignee")
  comments           Comment[]
  history            History[]
  supervisorMentions TicketSupervisor[] @relation("SupervisorMentions")

  @@map("usr_users")
}

model Ticket {
  id             Int      @id @default(autoincrement())
  title          String
  description    String
  priority       String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status         String   @default("NEW")    // NEW | IN_REVIEW | IN_PROGRESS | IN_TESTING | COMPLETED
  requestorId    Int
  assigneeId     Int?
  categoryId     Int?
  subCategoryId  Int?
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requestor    User               @relation("Requestor", fields: [requestorId], references: [id])
  assignee     User?              @relation("Assignee", fields: [assigneeId], references: [id])
  category     Category?          @relation(fields: [categoryId], references: [id])
  subCategory  SubCategory?       @relation(fields: [subCategoryId], references: [id])
  comments     Comment[]
  history      History[]
  supervisors  TicketSupervisor[]

  @@map("tkt_tickets")
}

// Etiquetas de supervisor en un ticket
model TicketSupervisor {
  ticketId     Int
  supervisorId Int
  createdAt    DateTime @default(now())

  ticket     Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  supervisor User   @relation("SupervisorMentions", fields: [supervisorId], references: [id])

  @@id([ticketId, supervisorId])
  @@map("tkt_supervisors")
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  subcategories SubCategory[]
  tickets       Ticket[]

  @@map("cfg_categories")
}

model SubCategory {
  id         Int      @id @default(autoincrement())
  name       String
  categoryId Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tickets  Ticket[]

  @@unique([name, categoryId])
  @@map("cfg_subcategories")
}

// Configuración por prioridad: qué canales activar
model NotificationSetting {
  id           Int     @id @default(autoincrement())
  priority     String  @unique // LOW | MEDIUM | HIGH | CRITICAL
  emailEnabled Boolean @default(false)
  smsEnabled   Boolean @default(false)

  @@map("ntf_settings")
}

// Lista de destinatarios (emails o teléfonos)
model NotificationRecipient {
  id        Int      @id @default(autoincrement())
  type      String   // email | sms
  value     String   // dirección de correo o número de teléfono
  name      String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("ntf_recipients")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  ticketId  Int
  userId    Int
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("tkt_comments")
}

model History {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  userId    Int
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("tkt_history")
}
